spellbook Map:
  init(inner):
    self.inner = inner
  
  spell keys():
    k = []
    for key in pairs(self.inner, "k"):
        k.append(key)
    return k

  spell values():
    v = []
    for value in pairs(self.inner, "v"):
        v.append(value)
    return v

  spell set(k, v):
    new_dict = self.inner
    new_dict[k] = v
    self.inner = new_dict

  spell get(k):
    return self.inner[k]

