spellbook Array:
  init(inner):
    """Array spellbook full of methods related to Arrays"""
    self.inner = inner

  spell append(item):
    self.inner = self.inner + [item]
    return self

  spell len():
    count = 0
    for i in self.inner:
      count++
    return count
  
  spell to_dict():
    array_dict = {}
    for k, v in enumerate(self.inner):
        array_dict[str(k)] = v
    self.inner = array_dict

